NODE_ENV=development
APP_PORT=3000
ENVIRONMENT=development

# Database (runtime user - subject to RLS)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sdui
DATABASE_USER=sdui_app
DATABASE_PASSWORD=sdui_app_password

# Database (owner - for migrations only)
DATABASE_OWNER_USER=sdui_owner
DATABASE_OWNER_PASSWORD=sdui_dev_password

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Security
LOCKOUT_DURATION_MINUTES=15
MAX_FAILED_ATTEMPTS=3
